{
  "name": "@fingerprint/svelte",
  "version": "2.2.1",
  "packageManager": "pnpm@9.12.2",
  "description": "Fingerprint Svelte SDK",
  "author": "Fingerprint, Inc (https://fingerprint.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fingerprintjs/svelte.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "private": false,
  "keywords": [
    "fraud",
    "fraud detection",
    "fraud prevention",
    "browser",
    "identification",
    "fingerprint",
    "fingerprinting",
    "browser fingerprint",
    "device fingerprint",
    "privacy"
  ],
  "scripts": {
    "prepare": "husky && pnpm sync-pkg-version",
    "build": "pnpm package",
    "package": "svelte-package",
    "package:watch": "svelte-package --watch",
    "check": "svelte-check --tsconfig tsconfig.json",
    "check:watch": "svelte-check --tsconfig tsconfig.json --watch",
    "check:examples": "bash scripts/check-examples.sh",
    "lint": "eslint --ext .js,.ts,.svelte --max-warnings 0 .",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:diff": "vitest run --coverage --reporter json --outputFile.json=report.json",
    "test:dts": "tsc --noEmit --isolatedModules dist/index.d.ts && pnpm check:examples",
    "test:svelte5": "pnpm --filter svelte5-tests test",
    "test:smoke": "bash __tests__/smoke/smoke-test.sh",
    "generate-version": "node scripts/syncVersion.js",
    "prebuild": "pnpm generate-version",
    "pretest": "pnpm generate-version",
    "precheck": "pnpm generate-version",
    "predocs": "pnpm generate-version",
    "sync-pkg-version": "node scripts/syncVersion.js && pnpm format",
    "build-all": "pnpm package && pnpm -r build",
    "docs": "pnpm package && typedoc dist/index.d.ts --options typedoc.cjs --out generated-docs",
    "changeset:version": "changeset version && pnpm sync-pkg-version",
    "changeset:publish": "HUSKY=0 changeset publish"
  },
  "dependencies": {
    "@fingerprint/agent": "^4.0.0"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^17.0.2",
    "@commitlint/config-conventional": "^17.0.2",
    "@fingerprintjs/changesets-changelog-format": "^0.2.0",
    "@fingerprintjs/commit-lint-dx-team": "^0.0.2",
    "@fingerprintjs/eslint-config-dx-team": "^0.1.0",
    "@fingerprintjs/prettier-config-dx-team": "^0.1.0",
    "@fingerprintjs/tsconfig-dx-team": "^0.0.2",
    "@sveltejs/adapter-auto": "^3.1.1",
    "@sveltejs/kit": "2.20.6",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.6.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "dotenv": "^16.0.1",
    "eslint": "^8.57.0",
    "eslint-plugin-svelte": "^2.46.1",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.2",
    "prettier-plugin-svelte": "^3.2.2",
    "svelte": "^4.2.20",
    "svelte-check": "^4.0.0",
    "svelte2tsx": "^0.7.5",
    "tslib": "^2.3.1",
    "typedoc": "^0.25.2",
    "typescript": "^5.4.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.ts": "pnpm run lint:fix",
    "*.svelte": "pnpm run lint:fix"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "typesVersions": {
    ">4.0": {
      "index.d.ts": [
        "./dist/index.d.ts"
      ]
    }
  }
}
